/**
 * Generate payment instructions HTML
 */
function generatePaymentInstructions($order, $paymentMethod) {
    $html = '';
    
    if ($paymentMethod === 'transfer') {
        $banks = getActiveBankAccounts();
        
        $html .= '<div class="payment-instructions">';
        $html .= '<h4><i class="fas fa-university"></i> Transfer ke Rekening Berikut:</h4>';
        
        foreach ($banks as $bank) {
            $html .= '<div class="bank-info">';
            $html .= '<strong>' . htmlspecialchars($bank['bank_name']) . '</strong><br>';
            $html .= '<span style="font-family: monospace; font-size: 18px;">';
            $html .= htmlspecialchars($bank['account_number']);
            $html .= '</span><br>';
            $html .= 'a.n ' . htmlspecialchars($bank['account_name']);
            
            if (!empty($bank['notes'])) {
                $html .= '<br><small>' . htmlspecialchars($bank['notes']) . '</small>';
            }
            
            $html .= '</div>';
        }
        
        $html .= '<div class="alert alert-warning" style="margin-top: 15px;">';
        $html .= '<i class="fas fa-exclamation-triangle"></i> ';
        $html .= '<strong>WAJIB UPLOAD BUKTI TRANSFER</strong> setelah melakukan transfer.';
        $html .= '</div>';
        $html .= '</div>';
        
    } elseif ($paymentMethod === 'qris') {
        $qrisSettings = getQRISSettings();
        
        $html .= '<div class="payment-instructions">';
        $html .= '<h4><i class="fas fa-qrcode"></i> Scan QR Code Berikut:</h4>';
        
        $qrisImage = BASE_URL . '/assets/qris/' . $qrisSettings['image_path'];
        $html .= '<div style="text-align: center; margin: 20px 0;">';
        
        if (file_exists($_SERVER['DOCUMENT_ROOT'] . parse_url($qrisImage, PHP_URL_PATH))) {
            $html .= '<img src="' . $qrisImage . '" alt="QRIS Code" style="max-width: 250px; height: auto;">';
        } else {
            $html .= '<div style="background: #f8f9fa; padding: 40px; border-radius: 10px;">';
            $html .= '<i class="fas fa-qrcode" style="font-size: 48px; color: #6c757d;"></i><br>';
            $html .= '<p>QRIS Code</p>';
            $html .= '</div>';
        }
        
        $html .= '</div>';
        
        $html .= '<div class="alert alert-info">';
        $html .= '<i class="fas fa-info-circle"></i> ';
        $html .= 'Scan QR code dengan aplikasi e-wallet atau mobile banking Anda.<br>';
        $html .= 'Pembayaran akan diverifikasi otomatis dalam 5-15 menit.';
        $html .= '</div>';
        $html .= '</div>';
    }
    
    return $html;
}

// Tambahkan setelah definisi UPLOADS_PATH
define('PROOF_UPLOAD_PATH', ROOT_PATH . 'assets/uploads/payment_proofs/');
define('QRIS_IMAGE_PATH', ROOT_PATH . 'assets/qris/');

// Tambahkan fungsi helper untuk upload
function getProofUploadPath() {
    $path = PROOF_UPLOAD_PATH;
    if (!is_dir($path)) {
        mkdir($path, 0777, true);
    }
    return $path;
}

function getQRISImagePath() {
    $path = QRIS_IMAGE_PATH;
    if (!is_dir($path)) {
        mkdir($path, 0755, true);
    }
    return $path;
}
