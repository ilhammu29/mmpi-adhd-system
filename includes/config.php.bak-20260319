/**
 * Get active bank accounts for display
 */
function getActiveBankAccounts() {
    $db = getDB();
    $banks = [];
    
    try {
        $stmt = $db->prepare("
            SELECT setting_value 
            FROM system_settings 
            WHERE category = 'bank_account' 
            AND setting_type = 'json'
        ");
        $stmt->execute();
        
        while ($row = $stmt->fetch()) {
            $bankData = json_decode($row['setting_value'], true);
            if ($bankData['is_active'] ?? false) {
                $banks[] = $bankData;
            }
        }
    } catch (Exception $e) {
        error_log("Error getting bank accounts: " . $e->getMessage());
    }
    
    return $banks;
}

/**
 * Format bank account for display
 */
function formatBankAccount($bank) {
    return $bank['bank_name'] . ' - ' . 
           $bank['account_number'] . ' a.n ' . 
           $bank['account_name'];
}

/**
 * Get QRIS settings
 */
function getQRISSettings() {
    $settings = [
        'enabled' => getSetting('qris_enabled', 0),
        'merchant_name' => getSetting('qris_merchant_name', APP_NAME),
        'merchant_city' => getSetting('qris_merchant_city', 'Jakarta'),
        'image_path' => getSetting('qris_image_path', 'qris-code.jpg'),
        'callback_url' => getSetting('qris_callback_url', BASE_URL . '/client/payment_callback.php'),
        'api_key' => getSetting('qris_api_key', ''),
        'api_secret' => getSetting('qris_api_secret', '')
    ];
    
    return $settings;
}

/**
 * Check if QRIS is enabled
 */
function isQRISEnabled() {
    return getSetting('qris_enabled', 0) == 1;
}

